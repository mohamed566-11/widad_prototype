{
    "version": 2,
    "installCommand": "pnpm install",
    "buildCommand": "pnpm --filter @workspace/api-server build",
    "outputDirectory": "artifacts/api-server/dist/public",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/server.js"
        },
        {
            "source": "/((?!api|assets|images|favicon.svg|logo.png|opengraph.jpg).*)",
            "destination": "/index.html"
        }
    ]
}